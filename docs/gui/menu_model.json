{
  "schema": "datum_menu_model_v1",
  "notes": "Data-driven GUI menu model: the menu bar and per-object marking menus as a table of label -> icon -> binding. A binding is exactly one of: 'verb' (a real datum.* verb, validated against mcp-server/datum_tool_catalog.json by scripts/check_menu_model.py), 'gui_local' (consumer-side view/shell action, no engine op), or 'not_built' (needed but no verb yet -> the authoring buildout worklist). Adding/removing/reassigning a menu item = editing one entry here (see DATUM_GUI_DESIGN_SPEC 'Modularity'). Marking-menu invariants: cardinal = N/E/S/W (<=4), secondary = diagonals (<=4), destructive never in 'secondary'. Realizes DATUM_GUI_CONTEXT_MENU_CONTENT.md.",
  "menubar": [
    {
      "menu": "File",
      "items": [
        {
          "label": "New Project",
          "icon": "file-new",
          "not_built": "engine-owned genesis; no public verb",
          "shortcut": "Ctrl+N"
        },
        {
          "label": "Open Project",
          "icon": "folder-open",
          "not_built": "GUI project-session model",
          "shortcut": "Ctrl+O"
        },
        {
          "label": "Import\u2026",
          "icon": "import",
          "not_built": "project import-kicad-* is CLI; no public import verb",
